  "card_defaults": {
    "background": "#FFFFFF",
    "ink": "#1A1A1A",
    "muted": "#666666",
    "border_radius": "4px",
    "shadow": "0 2px 12px rgba(0,0,0,0.05)",
    "padding": "var(--sp-8)"
  },
  "global_rules": {
    "min_density_pct": 75,
    "min_font_size": 22,
    "max_lines_xhs": {
      "display": 3,
      "body": 12
    }
  }
}
