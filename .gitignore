# 排除
.DS_Store
__pycache__/
*.pyc
node_modules/
.git/

# vault-meta — 只排除运行时锁，保留状态文件
.vault-meta/locks/

# Obsidian — 只忽略本地状态和缓存，同步配置
.obsidian/workspace.json
.obsidian/workspace-cache/
.obsidian/cache/

# 临时文件
*.swp
*.swo
*~
Temp/

